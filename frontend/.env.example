# Database (use PlanetScale, Railway, or Vercel-compatible MySQL for production)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=zym_dashboard
DB_USER=root
DB_PASSWORD=

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRY=7d

# Optional: override API base (default /api uses same Next.js app)
# NEXT_PUBLIC_API_URL=/api
