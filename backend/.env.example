# Database (XAMPP MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=zym_dashboard
DB_USER=root
DB_PASSWORD=

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
